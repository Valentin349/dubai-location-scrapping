  {
    "name": "Choithrams Deliveroo HOPs - Marina",
    "url": "https://riders.deliveroo.ae/en/news/deliveroo-choithrams-hops-marina",
    "phone": null,
    "floor": null,
    "unit": null,
    "content": [
